#!/usr/bin/env bash
# clorch notification handler — generated by clorch {{.Version}}
# DO NOT EDIT — regenerated on every `clorch init`
set -euo pipefail

STATE_DIR="{{.StateDir}}"

INPUT=$(cat)

SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty')
if [ -z "$SESSION_ID" ]; then exit 0; fi

STATE_FILE="$STATE_DIR/${SESSION_ID}.json"
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
MESSAGE=$(echo "$INPUT" | jq -r '.message // empty')
NOTIFICATION_TYPE=$(echo "$INPUT" | jq -r '.notification_type // empty')
PROJECT=$(echo "$INPUT" | jq -r '.cwd // empty' | xargs basename 2>/dev/null || echo "unknown")

if [ ! -f "$STATE_FILE" ]; then exit 0; fi

STATE=$(cat "$STATE_FILE")

STATE=$(echo "$STATE" | jq --arg msg "$MESSAGE" '.notification_message = $msg')
STATE=$(echo "$STATE" | jq --arg e "Notification" '.last_event = $e')
STATE=$(echo "$STATE" | jq --arg t "$NOW" '.last_event_time = $t')

NEW_STATUS=""
case "$NOTIFICATION_TYPE" in
    permission_prompt) NEW_STATUS="WAITING_PERMISSION" ;;
    elicitation_dialog) NEW_STATUS="WAITING_ANSWER" ;;
    idle_prompt) NEW_STATUS="WAITING_ANSWER" ;;
    *)
        MSG_LOWER=$(echo "$MESSAGE" | tr '[:upper:]' '[:lower:]')
        if echo "$MSG_LOWER" | grep -q "permission"; then
            NEW_STATUS="WAITING_PERMISSION"
        elif echo "$MSG_LOWER" | grep -qE "question|input|answer|elicitation"; then
            NEW_STATUS="WAITING_ANSWER"
        fi
        ;;
esac

if [ -n "$NEW_STATUS" ]; then
    STATE=$(echo "$STATE" | jq --arg s "$NEW_STATUS" '.status = $s')
fi

TMPFILE=$(mktemp "$STATE_DIR/.tmp.XXXXXX")
echo "$STATE" | jq '.' > "$TMPFILE"
mv "$TMPFILE" "$STATE_FILE"

printf '\a'

if command -v osascript &>/dev/null; then
    ESCAPED_MSG=$(echo "$MESSAGE" | sed 's/"/\\"/g' | head -c 200)
    osascript -e "display notification \"$ESCAPED_MSG\" with title \"clorch — $PROJECT\"" 2>/dev/null &
fi
